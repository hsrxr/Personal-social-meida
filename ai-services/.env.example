# AI Services - Environment Variables
# 复制此文件为 .env 并填入真实值

# --- LLM ---
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_VISION_MODEL=gpt-4o

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Agent-C ---
AGENT_C_BASE_URL=http://localhost:8001

# --- ASR ---
ASR_PROVIDER=openai
WHISPER_MODEL=base

# --- TTS ---
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural

# --- Embedding ---
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512

# --- Matching ---
MATCH_TOP_K=3
MATCH_COLD_START_THRESHOLD=100

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8002
DEBUG=false
